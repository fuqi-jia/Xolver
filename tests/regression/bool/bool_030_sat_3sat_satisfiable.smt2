; Random 3-SAT: 5 vars, 8 clauses, satisfiable.
(set-logic QF_UF)
(set-info :status sat)
(declare-const a Bool) (declare-const b Bool) (declare-const c Bool)
(declare-const d Bool) (declare-const e Bool)
(assert (or a b c))
(assert (or (not a) b c))
(assert (or a (not b) c))
(assert (or a b (not c)))
(assert (or (not a) (not b) c))
(assert (or (not a) b (not c)))
(assert (or a d e))
(assert (or (not d) (not e) c))
(check-sat)
