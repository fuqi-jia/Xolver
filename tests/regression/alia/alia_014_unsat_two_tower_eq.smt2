(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const x Int)
(declare-const y Int)
(assert (= (store (store a 1 10) 2 20) (store (store b 2 20) 1 10)))
(assert (= x (select a 3)))
(assert (= y (select b 3)))
(assert (distinct x y))
(check-sat)
