(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b1 (Array Int Int))
(declare-const b2 (Array Int Int))
(declare-const c1 (Array Int Int))
(declare-const c2 (Array Int Int))
(declare-const i1 Int)
(declare-const i2 Int)
(declare-const j Int)
(assert (= b1 (store a i1 5)))
(assert (= b2 (store b1 i2 7)))
(assert (= c1 (store a i2 7)))
(assert (= c2 (store c1 i1 5)))
(assert (distinct i1 i2))
(assert (distinct j i1))
(assert (distinct j i2))
(assert (distinct (select b2 j) (select c2 j)))
(check-sat)
