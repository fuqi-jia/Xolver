(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const i Int)
(declare-const j Int)
(declare-const k Int)
(assert (= (store a i (select a i)) (store b j (select b j))))
(assert (= a (store b k 3)))
(assert (= (select b k) 3))
(assert (distinct (select a j) (select b j)))
(check-sat)
