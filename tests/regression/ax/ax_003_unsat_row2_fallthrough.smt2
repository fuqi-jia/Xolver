(set-logic QF_AX)
(set-info :status unsat)
(declare-sort I 0)
(declare-sort E 0)
(declare-const a (Array I E))
(declare-const i I)
(declare-const j I)
(declare-const v E)
(declare-const w E)
(assert (not (= i j)))
(assert (= (select a j) w))
(assert (not (= (select (store a i v) j) w)))
(check-sat)
