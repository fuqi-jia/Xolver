(set-logic QF_AX)
(set-info :status unsat)
(declare-sort I 0)
(declare-sort J 0)
(declare-sort E 0)
(declare-const A (Array I (Array J E)))
(declare-const B (Array I (Array J E)))
(declare-const i I)
(declare-const inner (Array J E))
(assert (= A (store B i inner)))
(assert (= (select B i) inner))
(assert (distinct A B))
(check-sat)
