(set-logic QF_AX)
(set-info :status unsat)
(declare-sort I 0)
(declare-sort E 0)
(declare-const a (Array I E))
(declare-const b (Array I E))
(declare-const i I)
(declare-const j I)
(declare-const v E)
(assert (= b (store a i v)))
(assert (distinct i j))
(assert (distinct (select a j) (select b j)))
(check-sat)
