(set-logic QF_AX)
(set-info :status unsat)
(declare-sort I 0)
(declare-sort E 0)
(declare-const a (Array I E))
(declare-const b (Array I E))
(declare-const c (Array I E))
(declare-const d (Array I E))
(declare-const i I)
(declare-const j I)
(declare-const k I)
(declare-const v E)
(declare-const w E)
(assert (= b (store a i v)))
(assert (= c b))
(assert (= d (store c j w)))
(assert (distinct k i))
(assert (distinct k j))
(assert (distinct (select a k) (select d k)))
(check-sat)
