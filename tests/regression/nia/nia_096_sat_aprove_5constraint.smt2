; AProVE-like: 5-constraint nonlinear system, sat with explicit witness.
(set-logic QF_NIA)
(set-info :status sat)
(declare-const x Int)
(declare-const y Int)
(declare-const z Int)
(assert (>= x 0))
(assert (>= y 0))
(assert (>= z 0))
(assert (>= (+ (* x y) (* y z) (* x z)) 1))
(assert (<= (+ (* x x) (* y y) (* z z)) 100))
(assert (>= (+ x y z) 1))
(check-sat)
