; Three square terms x², y², z² — separate Square cut for each.
(set-logic QF_NIA)
(set-info :status sat)
(declare-const x Int)
(declare-const y Int)
(declare-const z Int)
(assert (>= (+ (* x x) (* y y) (* z z)) 0))
(assert (>= x 0)) (assert (<= x 5))
(assert (>= y 0)) (assert (<= y 5))
(assert (>= z 0)) (assert (<= z 5))
(check-sat)
