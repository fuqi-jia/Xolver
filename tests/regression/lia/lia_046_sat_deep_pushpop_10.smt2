; 10-deep push/pop, each layer adds a bound, all popped to original sat state.
(set-logic QF_LIA)
(set-info :status sat)
(declare-const x Int)
(assert (>= x 0))
(push 1) (assert (>= x 1))
(push 1) (assert (>= x 2))
(push 1) (assert (>= x 3))
(push 1) (assert (>= x 4))
(push 1) (assert (>= x 5))
(push 1) (assert (>= x 6))
(push 1) (assert (>= x 7))
(push 1) (assert (>= x 8))
(push 1) (assert (>= x 9))
(push 1) (assert (>= x 1000000))
(pop 10)
(assert (<= x 5))
(check-sat)
