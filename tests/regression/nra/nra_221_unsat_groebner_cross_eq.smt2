; NRA Gröbner target (XOLVER_NRA_GROBNER): a cross-equation obstruction with no single
; substitution — x*y=1 ∧ x*y*z=1 ⟹ z=1, then z*z=2 ⟹ 1=2. The ideal generated by the
; three equality polynomials contains 1 (no common complex root ⟹ no real root ⟹ unsat),
; which the bounded Buchberger reduction finds: [NRA-GROBNER] UNSAT cons=3. z3-confirmed.
(set-logic QF_NRA)
(set-info :status unsat)
(declare-const x Real)
(declare-const y Real)
(declare-const z Real)
(assert (= (* x y) 1))
(assert (= (* (* x y) z) 1))
(assert (= (* z z) 2))
(check-sat)
