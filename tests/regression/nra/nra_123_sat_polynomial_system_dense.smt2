; Dense polynomial system: 8 constraints on 3 vars, all consistent at (1,1,1).
(set-logic QF_NRA)
(set-info :status sat)
(declare-const x Real)
(declare-const y Real)
(declare-const z Real)
(assert (>= x 0)) (assert (<= x 2))
(assert (>= y 0)) (assert (<= y 2))
(assert (>= z 0)) (assert (<= z 2))
(assert (>= (* x y) 0))
(assert (>= (* y z) 0))
(assert (>= (* x z) 0))
(assert (>= (+ (* x x) (* y y) (* z z)) 1))
(assert (<= (+ (* x x) (* y y) (* z z)) 12))
(assert (>= (- x y) (- 2)))
(assert (<= (- x y) 2))
(check-sat)
