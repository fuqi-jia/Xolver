; 8-node DAG schedule: task i starts at t_i, dependency t_j - t_i ≥ duration_i.
(set-logic QF_IDL)
(set-info :status sat)
(declare-const t1 Int) (declare-const t2 Int) (declare-const t3 Int)
(declare-const t4 Int) (declare-const t5 Int) (declare-const t6 Int)
(declare-const t7 Int) (declare-const t8 Int)
(assert (>= (- t2 t1) 3))
(assert (>= (- t3 t1) 2))
(assert (>= (- t4 t2) 4))
(assert (>= (- t4 t3) 5))
(assert (>= (- t5 t4) 1))
(assert (>= (- t6 t4) 2))
(assert (>= (- t7 t5) 3))
(assert (>= (- t8 t6) 1))
(assert (>= (- t8 t7) 1))
(assert (>= t1 0))
(assert (<= t8 50))
(check-sat)
