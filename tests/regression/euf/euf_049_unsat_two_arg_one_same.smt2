; Binary function: a is shared, b=c, so f(a,b) = f(a,c). Asserting distinct values is unsat.
(set-logic QF_UF)
(set-info :status unsat)
(declare-sort U 0)
(declare-fun f (U U) U)
(declare-const a U)
(declare-const b U)
(declare-const c U)
(declare-const u U)
(declare-const v U)
(assert (= b c))
(assert (= (f a b) u))
(assert (= (f a c) v))
(assert (distinct u v))
(check-sat)
