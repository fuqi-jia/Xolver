; Deep push/pop with equality chain — each layer pushes a new eq, pop restores.
(set-logic QF_UF)
(set-info :status sat)
(declare-sort U 0)
(declare-const a U) (declare-const b U) (declare-const c U)
(declare-const d U) (declare-const e U)
(push 1) (assert (= a b))
(push 1) (assert (= b c))
(push 1) (assert (= c d))
(push 1) (assert (= d e))
(push 1) (assert (distinct a e))
(pop 5)
(assert (= a e))
(check-sat)
