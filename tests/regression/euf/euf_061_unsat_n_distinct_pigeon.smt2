; 5 distinct U elements but f range is 3 values — pigeonhole via congruence.
(set-logic QF_UF)
(set-info :status unsat)
(declare-sort U 0)
(declare-fun f (U) U)
(declare-const a U) (declare-const b U) (declare-const c U)
(declare-const d U) (declare-const e U)
(declare-const r1 U) (declare-const r2 U) (declare-const r3 U)
(assert (distinct a b c d e))
(assert (or (= (f a) r1) (= (f a) r2) (= (f a) r3)))
(assert (or (= (f b) r1) (= (f b) r2) (= (f b) r3)))
(assert (or (= (f c) r1) (= (f c) r2) (= (f c) r3)))
(assert (or (= (f d) r1) (= (f d) r2) (= (f d) r3)))
(assert (or (= (f e) r1) (= (f e) r2) (= (f e) r3)))
(assert (distinct (f a) (f b) (f c) (f d) (f e)))
(check-sat)
