; Long equality chain forces a=e, but we assert (distinct a e).
(set-logic QF_UF)
(set-info :status unsat)
(declare-sort U 0)
(declare-const a U)
(declare-const b U)
(declare-const c U)
(declare-const d U)
(declare-const e U)
(assert (= a b))
(assert (= b c))
(assert (= c d))
(assert (= d e))
(assert (distinct a e))
(check-sat)
