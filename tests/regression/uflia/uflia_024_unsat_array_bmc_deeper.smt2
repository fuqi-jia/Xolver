; 10-step BMC with UF-as-array + counter, bounded by constraint violation.
(set-logic QF_UFLIA)
(set-info :status unsat)
(declare-fun arr (Int) Int)
(declare-const k Int)
(assert (= (arr 0) 0))
(assert (= (arr 1) 1))
(assert (= (arr 2) 2))
(assert (= (arr 3) 3))
(assert (= (arr 4) 4))
(assert (= (arr 5) 5))
(assert (= (arr 6) 6))
(assert (= (arr 7) 7))
(assert (= (arr 8) 8))
(assert (= (arr 9) 9))
(assert (= k 5))
(assert (distinct (arr k) 5))
(check-sat)
