; 10-variable LRA system: all non-negative, sum = 10, all ≤ 2.
(set-logic QF_LRA)
(set-info :status sat)
(declare-const a Real) (declare-const b Real) (declare-const c Real)
(declare-const d Real) (declare-const e Real) (declare-const f Real)
(declare-const g Real) (declare-const h Real) (declare-const i Real)
(declare-const j Real)
(assert (>= a 0)) (assert (<= a 2))
(assert (>= b 0)) (assert (<= b 2))
(assert (>= c 0)) (assert (<= c 2))
(assert (>= d 0)) (assert (<= d 2))
(assert (>= e 0)) (assert (<= e 2))
(assert (>= f 0)) (assert (<= f 2))
(assert (>= g 0)) (assert (<= g 2))
(assert (>= h 0)) (assert (<= h 2))
(assert (>= i 0)) (assert (<= i 2))
(assert (>= j 0)) (assert (<= j 2))
(assert (= (+ a b c d e f g h i j) 10))
(check-sat)
